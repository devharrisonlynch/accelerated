{
  "name": "accelerated",
  "version": "0.2.0",
  "private": true,
  "description": "Permissionless perpetuals for the long tail of Solana memecoins — leverage every graduated Pump.fun coin up to 5x.",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@9.7.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "anchor:build": "anchor build",
    "anchor:test": "anchor test",
    "localnet": "bash scripts/localnet.sh",
    "seed:markets": "tsx scripts/seed-markets.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "turbo": "^2.0.9",
    "typescript": "^5.5.3"
  }
}
