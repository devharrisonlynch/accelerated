# Copy to .env and fill in. Never commit a real .env.

# RPC endpoint the terminal & scripts talk to
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_CLUSTER=devnet

# Deployed program id
NEXT_PUBLIC_PROGRAM_ID=ACCELeRAtedPRPxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# USDC (collateral) mint
NEXT_PUBLIC_COLLATERAL_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Path to the keypair used by anchor scripts / seeding
ANCHOR_WALLET=~/.config/solana/id.json
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
